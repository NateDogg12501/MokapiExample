# Copy this file to .env and fill in your weatherstack access key.
# Get a free key at https://weatherstack.com/ (or via apilayer).
# Only needed for the "hosted" source in the UI — the "mock" source
# works without any key at all.
WEATHERSTACK_ACCESS_KEY=

# Gmail credentials for the Email tab's "Google (real SMTP)" option — only
# needed if you want to send a real email instead of using the "Mokapi"
# option. GMAIL_USER is the sending Gmail address; GMAIL_APP_PASSWORD is a
# 16-character App Password (requires 2FA on the account), generated at
# https://myaccount.google.com/apppasswords. The "Mokapi" option works with
# no credentials at all.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Host ports (optional). Defaults match the values below. Only override
# these if you're running more than one checkout of this repo at once
# (e.g. separate git worktrees) and need each stack on its own ports.
#BACKEND_PORT=3000
#MOKAPI_DASHBOARD_PORT=8080
#MOKAPI_API_PORT=8090
#MOKAPI_SMTP_PORT=2525
