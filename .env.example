# Copy this file to .env and fill in your weatherstack access key.
# Get a free key at https://weatherstack.com/ (or via apilayer).
# Only needed for the "hosted" source in the UI — the "mock" source
# works without any key at all.
WEATHERSTACK_ACCESS_KEY=

# Gmail credentials for the Email tab's "Google (real SMTP)" option — only
# needed if you want to send a real email instead of using the "Mokapi"
# option. GMAIL_USER is the sending Gmail address; GMAIL_APP_PASSWORD is a
# 16-character App Password (requires 2FA on the account), generated at
# https://myaccount.google.com/apppasswords. The "Mokapi" option works with
# no credentials at all.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# AWS SQS queue name used by the AWS tab. Names both the queue
# docker-compose's localstack-init service creates for the "Localstack
# (local mock)" option, and the queue the backend resolves (but never
# creates) for the "AWS (real SQS)" option. Optional — defaults to
# mokapi-demo-queue if unset.
SQS_QUEUE_NAME=mokapi-demo-queue

# Free localstack account auth token, needed to start the localstack
# container at all — as of March 2026, localstack/localstack:latest merged
# its Community and Pro images into one that requires this even for
# community-tier services like SQS. Get one at https://app.localstack.cloud/
# (sign up, then generate a token from the web app) — no paid plan needed.
# Only needed for the AWS tab's "Localstack" option.
LOCALSTACK_AUTH_TOKEN=

# Real AWS credentials for the AWS tab's "AWS (real SQS)" option — only
# needed if you want to send to a real SQS queue instead of using the
# "Localstack" option. Passed through untouched to the backend container;
# the AWS SDK's default credential chain picks them up from there. The
# queue named by SQS_QUEUE_NAME above must already exist in this
# account/region — this demo never creates a real queue for you.
# AWS_SESSION_TOKEN is only needed for temporary/STS-issued credentials
# (an assumed role, SSO, or an MFA session token) — a regular IAM user's
# static access key doesn't have one; leave it blank in that case.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=

# Host ports (optional). Defaults match the values below. Only override
# these if you're running more than one checkout of this repo at once
# (e.g. separate git worktrees) and need each stack on its own ports.
#BACKEND_PORT=3000
#MOKAPI_DASHBOARD_PORT=8080
#MOKAPI_API_PORT=8090
#MOKAPI_SMTP_PORT=2525
#LOCALSTACK_PORT=4566
